<div class="FormWrapper container">
  <div class="FormContainer card">
    <h2>アカウント設定</h2>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, multipart: true }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <%# プロフィール画像 %>
      <div class="RoomForm__group text-center">
        <% avatar_url = resource.avatar? ? resource.avatar.url : "default_avatar.png" %>
        <%= image_tag avatar_url, class: "rounded-circle mb-2", width: 80, height: 80 %>
        <%= f.label :avatar, "プロフィール画像", class: "form-label" %>
        <%= f.file_field :avatar, class: "btn Button" %>
      </div>

      <div class="RoomForm__group">
        <%= f.label :name, "ユーザー名", class: "form-label required" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "form-control" %>
      </div>

      <div class="RoomForm__group">
        <%= f.label :bio, "自己紹介", class: "form-label" %>
        <%= f.text_area :bio, class: "form-control", placeholder: "自己紹介を入力（任意）" %>
      </div>

      <div class="RoomForm__group">
        <%= f.label :email, "メールアドレス", class: "form-label required" %>
        <%= f.email_field :email, autocomplete: "email", class: "form-control" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="alert alert-info">確認待ちのメールアドレス: <%= resource.unconfirmed_email %></div>
      <% end %>

      <div class="RoomForm__group">
        <%= f.label :password, "新しいパスワード", class: "form-label" %>
        <small class="text-muted">（変更しない場合は空欄）</small>
        <% if @minimum_password_length %>
          <small class="text-muted">（<%= @minimum_password_length %>文字以上）</small>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-control", placeholder: "新しいパスワード（変更する場合のみ）" %>
      </div>

      <div class="RoomForm__group">
        <%= f.label :password_confirmation, "新しいパスワード（確認）", class: "form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", placeholder: "新しいパスワードを再入力" %>
      </div>

      <div class="RoomForm__group">
        <%= f.label :current_password, "現在のパスワード", class: "form-label required" %>
        <small class="text-muted">（変更を保存するために必要です）</small>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control", placeholder: "現在のパスワードを入力" %>
      </div>

      <%= f.submit "更新する", class: "btn btn-primary Button" %>
      <%= link_to "キャンセル", :back, class: "btn btn-outline-primary Button" %>
    <% end %>

    <%# アカウント削除 %>
    <div class="mt-4 pt-3 border-top">
      <h5 class="text-danger">危険な操作</h5>
      <%= button_to "アカウントを削除する", registration_path(resource_name),
            data: { turbo_confirm: "本当にアカウントを削除しますか？この操作は取り消せません。" },
            method: :delete,
            class: "btn btn-outline-danger" %>
    </div>
  </div>
</div>
