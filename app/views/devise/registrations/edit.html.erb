<section class="UserSection">
  <h2>設定</h2>
  <div class="UserContainer container">
    <%= render "shared/settings_nav" %>
    <div class="SettingsInfo">
      <div class="SettingsInfo__header">
        <h3>アカウント</h3>
      </div>
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, multipart: true }) do |f| %>
        <div class="SettingsInfo__group">
          <%= f.label :email, "メールアドレス", class: "form-label SettingsInfo__label" %>
          <%= f.email_field :email, autocomplete: "email", class: "form-control" %>
        </div>

        <div class="SettingsInfo__group">
          <%= f.label :password, "変更後のパスワード", class: "form-label SettingsInfo__label" %>
          <small class="text-muted">※変更する場合のみ</small>
          <% if @minimum_password_length %>
            <small class="text-muted">（<%= @minimum_password_length %>文字以上）</small>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control", placeholder: "変更後のパスワードを再入力" %>
        </div>

        <div class="SettingsInfo__group">
          <%= f.label :password_confirmation, "確認用パスワード", class: "form-label"%>
          <small class="text-muted">※変更する場合のみ</small>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", placeholder: "変更後のパスワードを再入力" %>
        </div>

        <div class="SettingsInfo__group">
          <%= f.label :current_password, "現在のパスワード", class: "form-label"%>
          <%= f.password_field :current_password, autocomplete: "current_password", class: "form-control", placeholder: "現在のパスワードを入力" %>
        </div>

        <div class="SettingInfo__btn">
          <%= link_to "キャンセル", profile_users_path, class: "btn btn-outline-primary Button" %>
          <%= f.submit "保存", class: "btn btn-primary Button"%>
        </div>
      <% end %>
    </div>
  </div>
</section>
