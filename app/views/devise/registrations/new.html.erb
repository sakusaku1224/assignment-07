<div class="FormWrapper container">
  <div class="FormContainer card">
    <h2>新規登録</h2>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { multipart: true, novalidate: true }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="RoomForm__group">
        <%= f.label :name, "ユーザー名", class: "form-label required" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "form-control", placeholder: "ユーザー名を入力" %>
      </div>

      <div class="RoomForm__group">
        <%= f.label :email, "メールアドレス", class: "form-label required" %>
        <%= f.email_field :email, autocomplete: "email", class: "form-control", placeholder: "メールアドレスを入力" %>
      </div>

      <div class="RoomForm__group">
        <%= f.label :password, "パスワード", class: "form-label required" %>
        <% if @minimum_password_length %>
          <small class="text-muted">（<%= @minimum_password_length %>文字以上）</small>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-control", placeholder: "パスワードを入力" %>
      </div>

      <div class="RoomForm__group">
        <%= f.label :password_confirmation, "パスワード（確認）", class: "form-label required" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", placeholder: "パスワードを再入力" %>
      </div>


      <%= f.submit "登録する", class: "btn btn-primary Button" %>
      <%= link_to "ログインはこちら", new_user_session_path, class: "btn btn-outline-primary Button" %>
    <% end %>
  </div>
</div>
