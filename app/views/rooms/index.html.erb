<% if params[:area].nil? %>
<%# 空検索の場合、全件表示の検索結果ページに遷移する %>
  <div class="Hero">
    <section class="container">
      <h2 class="Hero__title">
        Potepan Shareで<br>
        まだ体験したことのない<br>
        旅をしよう
      </h2>
      <div class="HeroSearch">
        <%= form_with url: rooms_path, method: :get do |f|%>
          <%= f.text_field :area, placeholder: "エリア名を入力" %>
          <%= f.submit "検索", class: "btn" %>
        <% end %>
      </div>
    </section>  
  </div>
  <div class="container">
    <section class="RecommendArea">
      <h2 class="RecommendArea__title">
        おすすめのエリア
      </h2>
      <div class="RecommendArea__cards">
        <%= link_to rooms_path(area: "東京") do %>
          <%= image_tag "tokyo.png", alt: "東京", class: "RecommendArea__img" %>
          <span class="RecommendArea__name">東京</span>
          <span>
            <i class="bi bi-geo-alt-fill"></i> Tokyo
          </span>
        <% end %>
        <%= link_to rooms_path(area: "大阪") do %>
          <%= image_tag "osaka.png", alt: "大阪", class: "RecommendArea__img" %>
          <span class="RecommendArea__name">大阪</span>
          <span>
            <i class="bi bi-geo-alt-fill"></i> Osaka
          </span>
        <% end %>
        <%= link_to rooms_path(area: "京都") do %>
          <%= image_tag "kyoto.png", alt: "京都", class: "RecommendArea__img" %>
          <span class="RecommendArea__name">京都</span>
          <span>
            <i class="bi bi-geo-alt-fill"></i> Kyoto
          </span>
        <% end %>
        <%= link_to rooms_path(area: "札幌") do %>
          <%= image_tag "sapporo.png", alt: "札幌", class: "RecommendArea__img" %>
          <span class="RecommendArea__name">札幌</span>
          <span>
            <i class="bi bi-geo-alt-fill"></i> Sapporo
          </span>
        <% end %>
      </div>
    </section>
  </div>
<% else %>
  <%# 検索フォーム %>
  <%= render "search_form" %>
  <%# 部屋一覧 %>
  <div class="RoomsContainer container">
    <div class="RoomsContainer__result">
      <p class="Rooms__count"><span class="Rooms__count__num"><%= @rooms.count%></span>件が見つかりました。</p>
    </div>
    <ul class="Rooms__list">
      <% @rooms.each do |room| %>
        <li class="Room__item card">
          <%= image_tag room.image.url, alt: "部屋", class: "card-img-top" %>
          <div class="card-body">
            <p class="Room__name"><%= room.name%></p>
            <p class="Room__address"><%= room.address%></p>
            <%# 星 %>
            <span class="Room__stars">
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-fill"></i>
            </span>
            <p class="Room__description"><%= room.description%></p>
            <p class="Room__price">¥<%= room.price%>~</p>
            <%= link_to "詳細はこちら", room_path(room), class: "btn Room__btn"%>
          </div>
        </li>
      <% end%>
    </ul>
  </div>
<% end %>
